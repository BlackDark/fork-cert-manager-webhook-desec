# Minimal runtime image built from pre-compiled binaries.
# Used by the release-image CI workflow — Go cross-compilation happens on the
# runner (native, no QEMU), so this stage only does COPY operations.
FROM scratch
ARG TARGETARCH
COPY release/webhook-linux-${TARGETARCH} /webhook
COPY release/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
USER 65532:65532
ENTRYPOINT ["/webhook"]
